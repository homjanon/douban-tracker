# ===== 必填：豆瓣登录态 Cookie（私仓 Settings → Secrets 注入，勿提交）=====
DOUBAN_COOKIE=bid=xxx; ck=xxx; etc

# 追踪的豆瓣小组 URL（楼主发言所在组，多组逗号分隔）
DOUBAN_GROUP_URLS=https://www.douban.com/group/your-group/

# 目标楼主昵称（用于过滤发言）
DOUBAN_TARGET_USER=楼主昵称

# ===== 选填：LLM 后端（agnes 主力 + Qwen 二级 + SenseNova 兜底）=====
# ① 主力：Agnes AI 免费多模态
AGNES_API_KEY=sk-xxx
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash

# ② 二级：NVIDIA Qwen3.5-122B-A10B（免费）
NVIDIA_API_KEY=nvapi-xxx

# ③ 兜底：商汤日日新 SenseNova 6.7 Flash-Lite（免费，Token Plan 限时免费）
SENSENOVA_API_KEY=sk-xxx
SENSENOVA_BASE_URL=https://token.sensenova.cn/v1
SENSENOVA_MODEL=sensenova-6.7-flash-lite

# ===== 抓取参数 =====
PAGES=3
RECENT_N=10
AGGREGATE_THRESHOLD=50
